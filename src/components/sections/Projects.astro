---
import Section from "../Section.astro"

interface Props { cv: any }
const { cv } = Astro.props
const { projects, skills } = cv

const isEn = Astro.currentLocale === 'en';
const title = isEn ? "Projects" : "Proyectos";
---

<Section id="projects" title={title}>
  <div class="projects-grid">
    {projects.map(({ url, description, highlights, name, isActive }: any) => {
      const projectSlug = name.toLowerCase().replace(/[^a-z0-9]+/g, '_').replace(/(^_|_$)/g, '');
      return (
        <article class="project-card">
          <div class="project-status">
            <span class={`status-dot ${isActive ? 'active' : ''}`}></span>
            <span class="status-label">{isActive ? (isEn ? 'ONLINE' : 'ACTIVO') : (isEn ? 'OFFLINE' : 'INACTIVO')}</span>
          </div>
          <div class="project-body">
            <h3>
              <a href={url} target="_blank" title={isEn ? `View project ${name}` : `Ver el proyecto ${name}`} data-track={`project_click_${projectSlug}`}>
                {name}
              </a>
              <svg class="external-icon" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            </h3>
            <p>{description}</p>
          </div>
          <div class="project-footer">
            <div class="stack-tags">
              {highlights.map((highlight: any) => {
                const skill = skills.find((s: any) => s.name === highlight);
                return (
                  <div class="stack-tag" title={highlight}>
                    {skill?.icon && (
                      <div class="skill-icon">
                        <iconify-icon icon={skill.icon}></iconify-icon>
                      </div>
                    )}
                    <span class="skill-name">{highlight}</span>
                  </div>
                );
              })}
            </div>
            <a href={url} target="_blank" class="project-action" data-track={`project_click_${projectSlug}`}>
              <span>{isEn ? 'ACCESS' : 'ACCEDER'}</span>
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
            </a>
          </div>
        </article>
      )
    })}
  </div>
</Section>

<style>
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  .project-card {
    position: relative;
    background: var(--bg-panel);
    border: 1px solid var(--border-color);
    display: flex;
    flex-direction: column;
    transition: all var(--transition-normal);
    overflow: hidden;
  }

  .project-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--accent-purple), transparent);
    opacity: 0;
    transition: opacity var(--transition-normal);
  }

  .project-card:hover {
    border-color: var(--border-hover);
    background: var(--bg-panel-hover);
    box-shadow: var(--glow-border);
  }

  .project-card:hover::before {
    opacity: 0.6;
  }

  .project-status {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    background: var(--bg-secondary);
    border-bottom: 1px solid var(--border-color);
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.12em;
  }

  .status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--text-muted);
  }

  .status-dot.active {
    background: var(--accent-green);
    box-shadow: 0 0 6px var(--accent-green);
    animation: statusPulse 2s ease-in-out infinite;
  }

  @keyframes statusPulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .status-label {
    color: var(--text-muted);
  }

  .status-dot.active + .status-label {
    color: var(--accent-green);
  }

  .project-body {
    padding: 16px 12px;
    flex: 1;
  }

  .project-body h3 {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 8px;
  }

  .project-body h3 a {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 500;
    color: var(--text-primary);
    transition: color var(--transition-fast);
  }

  .project-card:hover .project-body h3 a {
    color: var(--accent-purple);
  }

  .external-icon {
    color: var(--text-muted);
    opacity: 0;
    transition: opacity var(--transition-fast);
  }

  .project-card:hover .external-icon {
    opacity: 1;
  }

  .project-body p {
    font-size: 0.8rem;
    line-height: 1.6;
    color: var(--text-secondary);
  }

  .project-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px;
    border-top: 1px solid var(--border-color);
    gap: 8px;
  }

  .stack-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .stack-tag {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 4px 8px;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    transition: all var(--transition-fast);
  }

  .stack-tag:hover {
    background: var(--accent-purple-dim);
  }

  .skill-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-secondary);
    width: 14px;
    height: 14px;
  }

  .skill-icon iconify-icon {
    width: 14px;
    height: 14px;
    display: block;
  }

  .skill-name {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--text-secondary);
    letter-spacing: 0.03em;
  }

  .project-action {
    display: flex;
    align-items: center;
    gap: 4px;
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--text-muted);
    letter-spacing: 0.08em;
    transition: color var(--transition-fast);
    white-space: nowrap;
  }

  .project-action:hover {
    color: var(--accent-purple);
  }

  @media (width <= 768px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
