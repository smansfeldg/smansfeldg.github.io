---
import Section from "../Section.astro"

interface Props { cv: any }
const { cv } = Astro.props
type Skill = {
  name: string;
  level: string;
  category?: string;
  icon?: string;
};

type SkillGroup = {
  category: string;
  skills: Array<Skill>;
};

const skills = cv.skills as Array<Skill>

const isEn = Astro.currentLocale === 'en';
const title = isEn ? "Skills" : "Habilidades";

const groupedSkills: Array<SkillGroup> = skills.reduce((groups: Array<SkillGroup>, skill: Skill) => {
  const category = skill.category || (isEn ? "Other" : "Otros");
  const group = groups.find((item: SkillGroup) => item.category === category);

  if (group) {
    group.skills.push(skill);
  } else {
    groups.push({ category, skills: [skill] });
  }

  return groups;
}, [] as Array<SkillGroup>);

const getCategoryId = (category: string) => `skill-category-${category.toLowerCase().replace(/[^a-z0-9-]/g, "-")}`;
---

<Section id="skills" title={title}>
  <div class="skills-panel">
    <div class="panel-header">
      <span class="panel-label">{isEn ? 'CAPABILITIES' : 'CAPACIDADES'}</span>
      <span class="panel-count">{skills.length} {isEn ? 'modules' : 'módulos'}</span>
    </div>
    <div class="skill-groups">
      {groupedSkills.map((group: SkillGroup) => (
        <section class="skill-group" aria-labelledby={getCategoryId(group.category)}>
          <h3 id={getCategoryId(group.category)} class="skill-category">{group.category}</h3>
          <div class="skills-grid">
            {group.skills.map(({ name, icon, level }: Skill) => (
              <div class="skill-item" data-level={level} title={level}>
                <div class="skill-icon">
                  {icon && <iconify-icon icon={icon}></iconify-icon>}
                </div>
                <span class="skill-name">{name}</span>
              </div>
            ))}
          </div>
        </section>
      ))}
    </div>
  </div>
</Section>

<style>
  .skills-panel {
    background: var(--bg-panel);
    border: 1px solid var(--border-color);
    transition: border-color var(--transition-normal);
  }

  .skills-panel:hover {
    border-color: var(--border-hover);
  }

  .panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 16px;
    background: var(--bg-secondary);
    border-bottom: 1px solid var(--border-color);
  }

  .panel-label {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.15em;
    color: var(--accent-purple);
  }

  .panel-count {
    font-family: var(--font-mono);
    font-size: 9px;
    color: var(--text-muted);
    letter-spacing: 0.08em;
  }

  .skill-groups {
    display: grid;
    gap: 16px;
    padding: 16px;
  }

  .skill-group {
    display: grid;
    gap: 8px;
  }

  .skill-category {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.12em;
    color: var(--text-muted);
    text-transform: uppercase;
  }

  .skills-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .skill-item {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-grow: 1;
    gap: 8px;
    padding: 4px 8px;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    transition: all var(--transition-fast);
    position: relative;
  }

  .skill-item::after {
    content: attr(data-level);
    position: absolute;
    left: 50%;
    bottom: calc(100% + 6px);
    transform: translateX(-50%) translateY(2px);
    padding: 3px 6px;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.04em;
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--transition-fast), transform var(--transition-fast);
    z-index: 1;
    white-space: nowrap;
  }

  .skill-item:hover::after {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  .skill-item:hover {
    background: var(--accent-purple-dim);
  }

  .skill-icon { 
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-secondary);
    width: 14px;
    height: 14px;
    flex-shrink: 0;
  }

  .skill-icon iconify-icon,
  .skill-icon svg {
    width: 14px;
    height: 14px;
    display: block;
  }

  .skill-name {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-secondary);
    letter-spacing: 0.03em;
  }

  .skill-bar {
    width: 32px;
    height: 3px;
    background: var(--border-color);
    margin-left: 4px;
    overflow: hidden;
  }

  .skill-fill {
    height: 100%;
    background: var(--accent-purple);
    transition: width var(--transition-normal);
  }

  @media (width <= 768px) {
    .skill-groups {
      padding: 12px;
      gap: 14px;
    }

    .skill-item {
      padding: 6px 10px;
    }
  }
</style>
