---
import Section from "../Section.astro"

interface Props { cv: any }
const { cv } = Astro.props
const { skills } = cv

const isEn = Astro.currentLocale === 'en';
const title = isEn ? "Skills" : "Habilidades";
---

<Section id="skills" title={title}>
  <div class="skills-panel">
    <div class="panel-header">
      <span class="panel-label">{isEn ? 'CAPABILITIES' : 'CAPACIDADES'}</span>
      <span class="panel-count">{skills.length} {isEn ? 'modules' : 'módulos'}</span>
    </div>
    <div class="skills-grid">
      {skills.map(({ name, level, icon }: any) => {
        const width = (level === 'Advanced' || level === 'Avanzado') ? '100%' : (level === 'Intermediate' || level === 'Intermedio') ? '60%' : '30%'

        return (
          <div class="skill-item">
            <div class="skill-icon">
              {icon && <iconify-icon icon={icon}></iconify-icon>}
            </div>
            <span class="skill-name">{name}</span>
            {/* <div class="skill-bar">
              <div class="skill-fill" style={`width: ${width}`}></div>
            </div> */}
          </div>
        )
      })}
    </div>
  </div>
</Section>

<style>
  .skills-panel {
    background: var(--bg-panel);
    border: 1px solid var(--border-color);
    transition: border-color var(--transition-normal);
  }

  .skills-panel:hover {
    border-color: var(--border-hover);
  }

  .panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 16px;
    background: var(--bg-secondary);
    border-bottom: 1px solid var(--border-color);
  }

  .panel-label {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.15em;
    color: var(--accent-purple);
  }

  .panel-count {
    font-family: var(--font-mono);
    font-size: 9px;
    color: var(--text-muted);
    letter-spacing: 0.08em;
  }

  .skills-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    padding: 16px;
  }

  .skill-item {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-grow: 1;
    gap: 8px;
    padding: 8px 12px;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    transition: all var(--transition-fast);
    position: relative;
  }

  .skill-item:hover {
    border-color: var(--border-hover);
    background: var(--accent-purple-dim);
  }

  .skill-icon {
    display: flex;
    align-items: center;
    color: var(--text-secondary);
  }

  .skill-icon svg {
    width: 14px;
    height: 14px;
  }

  .skill-name {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-secondary);
    letter-spacing: 0.03em;
  }

  .skill-bar {
    width: 32px;
    height: 3px;
    background: var(--border-color);
    margin-left: 4px;
    overflow: hidden;
  }

  .skill-fill {
    height: 100%;
    background: var(--accent-purple);
    transition: width var(--transition-normal);
  }

  @media (width <= 768px) {
    .skills-grid {
      padding: 12px;
    }

    .skill-item {
      padding: 6px 10px;
    }
  }
</style>
