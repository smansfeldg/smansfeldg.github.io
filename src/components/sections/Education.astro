---
import Section from "../Section.astro"

interface Props { cv: any }
const { cv } = Astro.props
const { education } = cv

const isEn = Astro.currentLocale === 'en';
const title = isEn ? "Education" : "Educación";
---

<Section id="education" title={title}>
  <ul class="education-list">
    {education.map(({ institution, startDate, endDate, area, studyType }: any) => {
      const startYear = new Date(startDate).getFullYear()
      const endYear = endDate != null ? new Date(endDate).getFullYear() : (isEn ? "Present" : "Actual")

      return (
        <li>
          <article class="edu-card">
            <div class="edu-header">
              <div class="edu-title">
                <h3>{institution}</h3>
                <p class="edu-area">{area}{studyType ? ` — ${studyType}` : ''}</p>
              </div>
              <div class="edu-period">
                <span>{startYear}</span>
                <span class="sep">—</span>
                <span>{endYear}</span>
              </div>
            </div>
          </article>
        </li>
      )
    })}
  </ul>
</Section>

<style>
  .education-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .edu-card {
    background: var(--bg-panel);
    border: 1px solid var(--border-color);
    padding: 16px;
    transition: all var(--transition-normal);
  }

  .edu-card:hover {
    border-color: var(--border-hover);
    background: var(--bg-panel-hover);
  }

  .edu-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 16px;
  }

  .edu-title h3 {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    font-weight: 500;
    margin-bottom: 4px;
    color: var(--text-primary);
  }

  .edu-area {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--accent-purple);
  }

  .edu-period {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-muted);
    white-space: nowrap;
    padding: 4px 8px;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
  }

  .sep {
    opacity: 0.5;
  }

  @media (width <= 768px) {
    .edu-header {
      flex-direction: column;
      gap: 8px;
    }

    .edu-period {
      align-self: flex-start;
    }
  }
</style>
