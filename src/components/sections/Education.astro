---
import Section from "../Section.astro";

interface Props {
  cv: any;
}
const { cv } = Astro.props;
const { education, certificates } = cv;

const isEn = Astro.currentLocale === "en";
const title = isEn ? "Education & Certifications" : "Formación y Certificaciones";
---

<Section id="education" title={title} command="ls education/ certs/" index="05">
  <ul class="education-list">
    {
      education.map(
        ({ institution, url, startDate, endDate, area, studyType }: any) => {
          const startYear = new Date(startDate).getFullYear();
          const endYear =
            endDate != null
              ? new Date(endDate).getFullYear()
              : isEn
                ? "Present"
                : "Actual";
          const isOngoing = endDate == null;

          return (
            <li>
              <article class="edu-card">
                <div class="edu-icon" aria-hidden="true">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="m12 3 10 5-10 5L2 8l10-5Z"/><path d="M6 10.6V16c0 1 2.7 3 6 3s6-2 6-3v-5.4"/><path d="M22 8v6"/></svg>
                </div>
                <div class="edu-info">
                  <h3>
                    {url ? (
                      <a href={url} target="_blank" rel="noopener noreferrer">{institution}</a>
                    ) : (
                      institution
                    )}
                  </h3>
                  <p class="edu-area">
                    {area}
                    {studyType ? ` — ${studyType}` : ""}
                  </p>
                </div>
                <div class="edu-period">
                  <span>{startYear}</span>
                  <span class="sep" aria-hidden="true">—</span>
                  <span class={isOngoing ? "ongoing" : ""}>{endYear}</span>
                </div>
              </article>
            </li>
          );
        },
      )
    }
  </ul>

  {
    certificates && certificates.length > 0 && (
      <div class="certs-block" data-reveal>
        <div class="certs-header">
          <span class="certs-label">{isEn ? "CERTIFICATIONS" : "CERTIFICACIONES"}</span>
          <span class="certs-count">
            {String(certificates.length).padStart(2, "0")} {isEn ? "credentials" : "credenciales"}
          </span>
        </div>
        <div class="certs-grid">
          {certificates.map(({ name, issuer, year, url, logo }: any, index: number) => {
            const hasLink = Boolean(url);
            const Tag = hasLink ? "a" : "div";
            return (
              <Tag
                class={`cert-card ${hasLink ? "linked" : ""}`}
                {...(hasLink ? { href: url, target: "_blank", rel: "noopener noreferrer", "data-track": "cert_click" } : {})}
                data-reveal
                style={`--reveal-delay: ${index * 50}ms`}
              >
                <div class="cert-logo-wrap">
                  <img
                    class="cert-logo"
                    src={logo}
                    alt={`${issuer} badge`}
                    width="52"
                    height="52"
                    loading="lazy"
                  />
                </div>
                <div class="cert-info">
                  <span class="cert-name">{name}</span>
                  <span class="cert-issuer">{issuer}</span>
                  <div class="cert-meta">
                    <span class="cert-year">{year}</span>
                    {hasLink && (
                      <span class="cert-verify">
                        {isEn ? "VERIFY" : "VERIFICAR"}
                        <svg width="9" height="9" viewBox="0 0 10 10" fill="none" aria-hidden="true">
                          <path d="M1 9L9 1M9 1H3M9 1V7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                      </span>
                    )}
                  </div>
                </div>
              </Tag>
            );
          })}
        </div>
      </div>
    )
  }
</Section>

<style>
  .education-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 16px;
  }

  .edu-card {
    display: flex;
    align-items: center;
    gap: 16px;
    background: var(--bg-panel);
    border: 1px solid var(--border-color);
    padding: 16px 18px;
    transition: all var(--transition-normal);
  }

  .edu-card:hover {
    border-color: var(--border-hover);
    background: var(--bg-panel-hover);
  }

  .edu-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    flex-shrink: 0;
    background: var(--accent-purple-dim);
    border: 1px solid var(--border-color);
    color: var(--accent-purple-bright);
    clip-path: polygon(6px 0, 100% 0, 100% calc(100% - 6px), calc(100% - 6px) 100%, 0 100%, 0 6px);
  }

  .edu-info {
    flex: 1;
    min-width: 0;
  }

  .edu-info h3 {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 3px;
    color: var(--text-primary);
  }

  .edu-info h3 a {
    color: inherit;
    transition: color var(--transition-fast);
  }

  .edu-info h3 a:hover {
    color: var(--accent-purple-bright);
  }

  .edu-area {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--accent-purple-bright);
  }

  .edu-period {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-muted);
    white-space: nowrap;
    padding: 4px 9px;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
  }

  .sep {
    opacity: 0.5;
  }

  .ongoing {
    color: var(--accent-green);
  }

  /* ── Certifications ── */
  .certs-block {
    border: 1px solid var(--border-color);
    background: var(--bg-panel);
    transition: border-color var(--transition-normal);
  }

  .certs-block:hover {
    border-color: var(--border-hover);
  }

  .certs-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 9px 16px;
    background: var(--bg-secondary);
    border-bottom: 1px solid var(--border-color);
  }

  .certs-label {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.15em;
    color: var(--accent-purple);
  }

  .certs-count {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--text-muted);
    letter-spacing: 0.08em;
  }

  .certs-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--border-color);
  }

  /* ── Cert card ── */
  .cert-card {
    position: relative;
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 16px 18px;
    background: var(--bg-panel);
    color: inherit;
    overflow: hidden;
    transition: background var(--transition-fast);
  }

  a.cert-card:hover {
    background: var(--bg-panel-hover);
  }

  a.cert-card::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(105deg, transparent 40%, rgba(139, 92, 246, 0.06) 50%, transparent 60%);
    transform: translateX(-100%);
    transition: transform 600ms var(--ease-out-soft);
    pointer-events: none;
  }

  a.cert-card:hover::after {
    transform: translateX(100%);
  }

  a.cert-card:hover .cert-name {
    color: var(--accent-purple-bright);
  }

  .cert-logo-wrap {
    flex-shrink: 0;
    width: 52px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .cert-logo {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  .cert-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 3px;
    min-width: 0;
  }

  .cert-name {
    font-family: var(--font-heading);
    font-size: 0.86rem;
    font-weight: 600;
    color: var(--text-primary);
    transition: color var(--transition-fast);
    line-height: 1.3;
  }

  .cert-issuer {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--text-muted);
    letter-spacing: 0.04em;
  }

  .cert-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 4px;
  }

  .cert-year {
    font-family: var(--font-mono);
    font-size: 9.5px;
    color: var(--text-muted);
    padding: 1px 6px;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
  }

  .cert-verify {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.12em;
    color: var(--accent-cyan);
  }

  @media (width <= 768px) {
    .edu-card {
      flex-wrap: wrap;
      gap: 12px;
    }

    .edu-period {
      margin-left: 54px;
    }

    .certs-grid {
      grid-template-columns: 1fr;
    }

    .cert-card {
      padding: 14px 16px;
    }
  }
</style>
