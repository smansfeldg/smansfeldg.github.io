---
const isEn = Astro.currentLocale === 'en'

const NAV_ITEMS = [
  { id: "about", label: isEn ? "About" : "Perfil" },
  { id: "experience", label: isEn ? "Experience" : "Experiencia" },
  { id: "projects", label: isEn ? "Projects" : "Proyectos" },
  { id: "skills", label: "Skills" },
  { id: "education", label: isEn ? "Education" : "Formación" },
  { id: "contact", label: isEn ? "Contact" : "Contacto" },
]
---

<header id="topbar" class="no-print">
  <div class="topbar-inner">
    <a href="#hero" class="topbar-brand" data-track="nav_brand_click">
      <span class="brand-user">smansfeld</span><span class="brand-at">@</span><span class="brand-host">cloud</span><span class="brand-path">:~$</span>
      <span class="brand-cursor" aria-hidden="true"></span>
    </a>

    <nav class="topbar-nav" aria-label={isEn ? "Sections" : "Secciones"}>
      {NAV_ITEMS.map(({ id, label }) => (
        <a href={`#${id}`} class="nav-link" data-section={id} data-track={`nav_${id}_click`}>
          <span class="nav-caret" aria-hidden="true">&gt;</span>{label}
        </a>
      ))}
    </nav>

    <div class="topbar-controls">
      <button id="lang-toggle" class="control-btn" type="button" title={isEn ? "Cambiar a español" : "Switch to English"}>
        {isEn ? "ES" : "EN"}
      </button>
      <button id="theme-toggle" class="control-btn" type="button" aria-label={isEn ? "Toggle theme" : "Alternar tema"}>
        <svg class="icon-moon" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
        <svg class="icon-sun" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="4"/><path d="M12 2v2m0 16v2M4.9 4.9l1.4 1.4m11.4 11.4 1.4 1.4M2 12h2m16 0h2M4.9 19.1l1.4-1.4m11.4-11.4 1.4-1.4"/></svg>
      </button>
      <button id="palette-hint" class="control-btn palette-btn" type="button" title={isEn ? "Open command palette" : "Abrir paleta de comandos"}>
        <kbd id="palette-mod">Ctrl</kbd><kbd>K</kbd>
      </button>
    </div>
  </div>
  <div class="topbar-progress" aria-hidden="true"><div class="progress-fill" id="scroll-progress"></div></div>
</header>

<script>
  // ── Platform-aware palette hint ──
  const mod = document.getElementById("palette-mod")
  if (mod && navigator.userAgent.includes("Macintosh")) mod.textContent = "⌘"

  // ── Palette trigger ──
  document.getElementById("palette-hint")?.addEventListener("click", () => {
    import("@/analytics/events").then(({ trackEvent }) => trackEvent("command_palette_open"))
    ;(window as any).__openPalette?.()
  })

  // ── Theme toggle ──
  document.getElementById("theme-toggle")?.addEventListener("click", () => {
    import("@/analytics/events").then(({ trackEvent }) => trackEvent("command_toggle_theme"))
    const isDark = document.documentElement.classList.contains("dark")
    const newTheme = isDark ? "light" : "dark"
    ;(window as any).applyTheme(newTheme)
    localStorage.setItem("theme", newTheme)
  })

  // ── Language toggle ──
  document.getElementById("lang-toggle")?.addEventListener("click", () => {
    import("@/analytics/events").then(({ trackEvent }) => trackEvent("command_switch_language"))
    const currentIsEn = window.location.pathname.startsWith("/en")
    localStorage.setItem("lang", currentIsEn ? "es" : "en")
    window.location.href = currentIsEn ? "/" : "/en/"
  })

  // ── Scroll progress + condensed state ──
  const topbar = document.getElementById("topbar")
  const progress = document.getElementById("scroll-progress")

  let scrollRaf: number | undefined
  const onScroll = () => {
    const doc = document.documentElement
    const max = doc.scrollHeight - doc.clientHeight
    const pct = max > 0 ? (window.scrollY / max) * 100 : 0
    if (progress) progress.style.width = `${pct}%`
    topbar?.classList.toggle("scrolled", window.scrollY > 12)
  }

  window.addEventListener("scroll", () => {
    if (scrollRaf) cancelAnimationFrame(scrollRaf)
    scrollRaf = requestAnimationFrame(onScroll)
  }, { passive: true })
  onScroll()

  // ── Scrollspy ──
  const links = new Map<string, HTMLElement>()
  document.querySelectorAll<HTMLElement>(".nav-link[data-section]").forEach((el) => {
    links.set(el.dataset.section ?? "", el)
  })

  if ("IntersectionObserver" in window && links.size) {
    let activeId = ""
    const spy = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          activeId = entry.target.id
          links.forEach((link, id) => link.classList.toggle("active", id === activeId))
        }
      })
    }, { rootMargin: "-40% 0px -55% 0px" })

    links.forEach((_link, id) => {
      const section = document.getElementById(id)
      if (section) spy.observe(section)
    })
  }
</script>

<style>
  #topbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: color-mix(in srgb, var(--bg-primary) 78%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border-color);
    transition: background var(--transition-normal), border-color var(--transition-normal);
  }

  #topbar.scrolled {
    background: color-mix(in srgb, var(--bg-primary) 92%, transparent);
    border-bottom-color: var(--border-hover);
  }

  .topbar-inner {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--container-pad);
    height: var(--topbar-h);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  /* ── Brand ── */
  .topbar-brand {
    display: flex;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.02em;
    white-space: nowrap;
  }

  .brand-user { color: var(--accent-purple); }
  .brand-at { color: var(--text-muted); }
  .brand-host { color: var(--accent-cyan); }
  .brand-path { color: var(--text-secondary); margin-left: 1px; }

  .brand-cursor {
    display: inline-block;
    width: 6px;
    height: 12px;
    margin-left: 4px;
    background: var(--accent-purple);
    animation: blink 1.1s step-end infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  /* ── Nav ── */
  .topbar-nav {
    display: flex;
    align-items: center;
    gap: 2px;
    overflow: hidden;
  }

  .nav-link {
    position: relative;
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 5px 9px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-muted);
    transition: color var(--transition-fast), background var(--transition-fast);
  }

  .nav-caret {
    color: var(--accent-purple);
    opacity: 0;
    transform: translateX(-3px);
    transition: opacity var(--transition-fast), transform var(--transition-fast);
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--text-primary);
    background: var(--accent-purple-dim);
  }

  .nav-link:hover .nav-caret,
  .nav-link.active .nav-caret {
    opacity: 1;
    transform: translateX(0);
  }

  .nav-link.active {
    color: var(--accent-purple-bright);
  }

  /* ── Controls ── */
  .topbar-controls {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .control-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 3px;
    height: 26px;
    min-width: 30px;
    padding: 0 7px;
    background: var(--bg-panel);
    border: 1px solid var(--border-color);
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.08em;
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .control-btn:hover {
    color: var(--text-primary);
    border-color: var(--border-hover);
    background: var(--accent-purple-dim);
  }

  .control-btn kbd {
    font-family: var(--font-mono);
    font-size: 10px;
    color: inherit;
  }

  /* Theme icon swap */
  .icon-sun { display: none; }
  :global(html:not(.dark)) .icon-sun { display: block; }
  :global(html:not(.dark)) .icon-moon { display: none; }

  /* ── Scroll progress ── */
  .topbar-progress {
    height: 1px;
    background: transparent;
  }

  .progress-fill {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, var(--accent-purple), var(--accent-cyan));
    box-shadow: 0 0 8px rgba(139, 92, 246, 0.5);
  }

  @media (width <= 900px) {
    .topbar-nav { display: none; }

    .topbar-inner {
      padding: 0 18px;
    }
  }

  @media (width <= 480px) {
    .brand-path, .brand-cursor { display: none; }
    .palette-btn { display: none; }
  }
</style>
