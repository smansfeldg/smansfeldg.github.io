---
interface Props {
  id: string;
}

const { id } = Astro.props;
---

<!-- Clarity, deferred to idle so it stays off the critical path.
     The queue shim is installed synchronously, so any clarity() call made
     before the tag loads is buffered and replayed, exactly as upstream. -->
<script is:inline type="text/javascript" define:vars={{ clarityId: id }}>
    (function (c, l, a, r, i) {
        c[a] = c[a] || function () { (c[a].q = c[a].q || []).push(arguments) };

        var loaded = false;
        function loadClarity() {
            if (loaded) return;
            loaded = true;
            var t = l.createElement(r);
            t.async = 1;
            t.src = "https://www.clarity.ms/tag/" + i;
            var y = l.getElementsByTagName(r)[0];
            y.parentNode.insertBefore(t, y);
        }

        if ("requestIdleCallback" in c) {
            c.requestIdleCallback(loadClarity, { timeout: 4000 });
        } else {
            c.addEventListener("load", function () { c.setTimeout(loadClarity, 1500) });
        }
    })(window, document, "clarity", "script", clarityId);
</script>
