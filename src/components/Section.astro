---
interface Props {
  id: string
  title?: string
  command?: string
  index?: string
}

const { title, id, command, index } = Astro.props
---

<section id={id} class="site-section" data-reveal>
  {title && (
    <header class="section-head">
      <div class="head-meta">
        {index && <span class="head-index">[{index}]</span>}
        <span class="head-prompt" aria-hidden="true">$</span>
        {command && <span class="head-command" aria-hidden="true">{command}</span>}
        <span class="head-line" aria-hidden="true"></span>
      </div>
      <h2 class="head-title">
        {title}<span class="title-caret" aria-hidden="true">▌</span>
      </h2>
    </header>
  )}
  <div class="section-content">
    <slot />
  </div>
</section>

<style>
  .site-section {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--container-pad);
    scroll-margin-top: calc(var(--topbar-h) + 32px);
  }

  .site-section + .site-section,
  :global(.site-section ~ .site-section) {
    margin-top: 96px;
  }

  .section-head {
    margin-bottom: 28px;
  }

  .head-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    margin-bottom: 8px;
  }

  .head-index {
    color: var(--accent-cyan);
    font-weight: 600;
  }

  .head-prompt {
    color: var(--accent-purple);
    font-weight: 700;
  }

  .head-command {
    color: var(--text-muted);
  }

  .head-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, var(--border-color), transparent);
    margin-left: 8px;
  }

  .head-title {
    font-family: var(--font-heading);
    font-size: 1.65rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--text-primary);
  }

  .title-caret {
    color: var(--accent-purple);
    font-size: 0.85em;
    margin-left: 6px;
    animation: caretBlink 1.2s step-end infinite;
  }

  @keyframes caretBlink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  @media (width <= 768px) {
    .site-section {
      padding: 0 18px;
    }

    .site-section + .site-section,
    :global(.site-section ~ .site-section) {
      margin-top: 64px;
    }

    .section-head {
      margin-bottom: 20px;
    }

    .head-title {
      font-size: 1.35rem;
    }
  }

  @media print {
    .site-section + .site-section,
    :global(.site-section ~ .site-section) {
      margin-top: 24px;
    }

    .head-meta {
      display: none;
    }

    .title-caret {
      display: none;
    }

    .section-head {
      margin-bottom: 12px;
    }
  }
</style>
