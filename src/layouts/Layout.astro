---
import AIContext from "@/components/AIContext.astro"

type LocaleCode = "es_AR" | "en_US" | string
type AlternateLocale = {
  locale: LocaleCode
  href: string
  hreflang?: string
}

interface Props {
  title: string
  cv: any
  description?: string
  image?: string
  canonical?: string
  locale?: LocaleCode
  alternateLocales?: AlternateLocale[]
}

const {
  title,
  cv,
  description,
  image,
  canonical,
  locale,
  alternateLocales,
} = Astro.props

const { basics, education } = cv
const { name, label, email, phone, summary, url, profiles } = basics
const site = Astro.site ?? new URL(Astro.url.origin)
const defaultOgImage = "/og-home.png"
const pageDescription = description ?? summary
const canonicalUrl = new URL(canonical ?? Astro.url.pathname, site)
const ogImageUrl = new URL(image || defaultOgImage, site)
const profileImageUrl = new URL(basics.image, site)
const currentOgLocale = locale ?? (Astro.currentLocale === "en" ? "en_US" : "es_AR")
const defaultAlternateLocales: AlternateLocale[] = [
  { locale: "es_AR", href: "/", hreflang: "es-AR" },
  { locale: "en_US", href: "/en/", hreflang: "en-US" },
]
const localeAlternates = alternateLocales ?? defaultAlternateLocales
const toHreflang = (value: string) => value.replace("_", "-")
const alternateLinks = localeAlternates.map((alternate) => ({
  ...alternate,
  href: new URL(alternate.href, site).href,
  hreflang: alternate.hreflang ?? toHreflang(alternate.locale),
}))
const xDefaultAlternate = alternateLinks.find(({ locale }) => locale === "es_AR") ?? alternateLinks[0]
const ogLocaleAlternates = [...new Set(
  localeAlternates
    .map(({ locale }) => locale)
    .filter((alternateLocale) => alternateLocale !== currentOgLocale)
)]
const sameAs = profiles?.map(({ url }: { url: string }) => url).filter(Boolean) ?? []
const currentWork = cv.work?.find(({ endDate }: { endDate: string | null }) => endDate === null) ?? cv.work?.[0]
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name,
  jobTitle: label,
  url: new URL(url, site).href,
  image: profileImageUrl.href,
  email: `mailto:${email}`,
  telephone: phone,
  sameAs,
  worksFor: currentWork?.name ? {
    "@type": "Organization",
    name: currentWork.name,
    ...(currentWork.url ? { url: currentWork.url } : {}),
  } : undefined,
  alumniOf: education?.[0]?.institution ? {
    "@type": "CollegeOrUniversity",
    name: education[0].institution,
    ...(education[0].url ? { url: education[0].url } : {}),
  } : undefined,
  knowsAbout: [
    "Kubernetes",
    "AWS",
    "CI/CD",
    "DevOps",
    "Cloud Infrastructure",
  ],
}
const safeJsonLd = JSON.stringify(jsonLd).replace(/</g, "\\u003c")
---

<!doctype html>
<html lang={Astro.currentLocale || "es"}>
  <head>
    <meta charset="UTF-8" />
    <title>{title}</title>
    <meta name="description" content={pageDescription} />
    <meta name="viewport" content="width=device-width" />
    <link rel="canonical" href={canonicalUrl.href} />
    {alternateLinks.map(({ href, hreflang }) => (
      <link rel="alternate" hreflang={hreflang} href={href} />
    ))}
    {xDefaultAlternate && (
      <link rel="alternate" hreflang="x-default" href={xDefaultAlternate.href} />
    )}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preload" as="image" href={basics.image} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@300;400;500;600&display=swap" rel="stylesheet" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:image" content={ogImageUrl.href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={currentOgLocale} />
    {ogLocaleAlternates.map((alternateLocale) => (
      <meta property="og:locale:alternate" content={alternateLocale} />
    ))}
    <meta property="og:site_name" content="Santiago Ariel Mansfeld" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImageUrl.href} />
    <script type="application/ld+json" set:html={safeJsonLd}></script>
    <script src="https://code.iconify.design/iconify-icon/2.1.0/iconify-icon.min.js"></script>
    <script is:inline>
      window.getThemePreference = () => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      };
      
      window.applyTheme = (theme) => {
        if (theme === 'dark') {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
      };

      const initTheme = () => {
        const theme = window.getThemePreference();
        window.applyTheme(theme);
      };
      
      initTheme();

      const initLang = () => {
        const storedLang = localStorage.getItem('lang');
        const currentIsEn = window.location.pathname.startsWith('/en');
        
        if (storedLang === 'en' && !currentIsEn) {
          window.location.replace('/en/');
        } else if (storedLang === 'es' && currentIsEn) {
          window.location.replace('/');
        } else if (!storedLang) {
          const browserIsEn = navigator.language.startsWith('en');
          if (browserIsEn && !currentIsEn) {
            window.location.replace('/en/');
          } else if (!browserIsEn && currentIsEn) {
            window.location.replace('/');
          }
        }
      };
      
      initLang();
    </script>
  </head>
  <body>
    <AIContext />
    <div class="bg-effects">
      <div class="bg-grid"></div>
      <div class="bg-gradient-fog"></div>
      <div class="bg-radial-light"></div>
      <div class="bg-noise"></div>
    </div>

    <div class="app-layout">
      <slot />
    </div>
  </body>
</html>

<style is:global>
  :root {
    --bg-primary: #050505;
    --bg-secondary: #0A0A0F;
    --bg-panel: #0D0D14;
    --bg-panel-hover: #111118;
    --text-primary: #E8E6F0;
    --text-secondary: #9890A8;
    --text-muted: #5A5470;
    --border-color: rgba(120, 80, 180, 0.12);
    --border-hover: rgba(140, 100, 200, 0.25);
    --accent-purple: #8B5CF6;
    --accent-purple-dim: rgba(139, 92, 246, 0.15);
    --accent-magenta: rgba(180, 100, 220, 0.6);
    --accent-cyan: rgba(80, 200, 220, 0.5);
    --accent-orange: rgba(240, 160, 80, 0.5);
    --accent-green: rgba(80, 200, 120, 0.6);
    --glow-purple: 0 0 20px rgba(139, 92, 246, 0.1);
    --glow-border: 0 0 8px rgba(139, 92, 246, 0.08);
    --font-heading: 'Space Grotesk', system-ui, sans-serif;
    --font-body: 'Inter', system-ui, sans-serif;
    --font-mono: 'JetBrains Mono', 'Fira Code', monospace;
    --radius-sm: 2px;
    --radius-md: 4px;
    --transition-fast: 150ms ease;
    --transition-normal: 250ms ease;
  }
  
  :root.dark {
    --bg-primary: #050505;
    --bg-secondary: #0A0A0F;
    --bg-panel: #0D0D14;
    --bg-panel-hover: #111118;
    --text-primary: #E8E6F0;
    --text-secondary: #9890A8;
    --text-muted: #5A5470;
    --border-color: rgba(120, 80, 180, 0.12);
    --border-hover: rgba(140, 100, 200, 0.25);
  }

  :root:not(.dark) {
    --bg-primary: #F5F3F7;
    --bg-secondary: #EDE8F5;
    --bg-panel: #FFFFFF;
    --bg-panel-hover: #F8F6FC;
    --text-primary: #1A1525;
    --text-secondary: #5A5470;
    --text-muted: #8A82A0;
    --border-color: rgba(120, 80, 180, 0.15);
    --border-hover: rgba(120, 80, 180, 0.3);
    --accent-purple-dim: rgba(139, 92, 246, 0.08);
    --glow-purple: 0 0 20px rgba(139, 92, 246, 0.05);
    --glow-border: 0 0 8px rgba(139, 92, 246, 0.03);
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
    background: var(--bg-primary);
    color: var(--text-primary);
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    min-height: 100vh;
    overflow-x: hidden;
  }

  a {
    text-decoration: none;
    color: inherit;
  }

  ul {
    list-style: none;
  }

  h1, h2, h3, h4, h5, h6 {
    font-family: var(--font-heading);
    font-weight: 500;
    line-height: 1.3;
    color: var(--text-primary);
  }

  p {
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .bg-effects {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .bg-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--border-color) 1px, transparent 1px),
      linear-gradient(90deg, var(--border-color) 1px, transparent 1px);
    background-size: 60px 60px;
    opacity: 0.4;
  }

  .bg-gradient-fog {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 50% at 20% 40%, rgba(139, 92, 246, 0.04), transparent),
      radial-gradient(ellipse 60% 40% at 80% 60%, rgba(80, 200, 220, 0.03), transparent);
    animation: fogDrift 20s ease-in-out infinite alternate;
  }

  @keyframes fogDrift {
    0% { transform: translate(0, 0); }
    100% { transform: translate(-2%, 1%); }
  }

  .bg-radial-light {
    position: absolute;
    top: -20%;
    right: -10%;
    width: 60%;
    height: 60%;
    background: radial-gradient(circle, rgba(139, 92, 246, 0.06), transparent 70%);
    filter: blur(40px);
  }

  .bg-noise {
    position: absolute;
    inset: 0;
    opacity: 0.015;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 256px 256px;
  }

  .app-layout {
    position: relative;
    z-index: 1;
    min-height: 100vh;
  }

  .print {
    display: none !important;
  }

  @media print {
    .no-print {
      display: none !important;
    }

    .print {
      display: block !important;
    }

    .bg-effects {
      display: none;
    }

    article {
      break-inside: avoid;
    }
  }
</style>
