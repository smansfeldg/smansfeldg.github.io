---
import AIContext from "@/components/AIContext.astro"
import Clarity from "@/components/Clarity.astro"

type LocaleCode = "es_AR" | "en_US" | string
type AlternateLocale = {
  locale: LocaleCode
  href: string
  hreflang?: string
}

interface Props {
  title: string
  cv: any
  description?: string
  image?: string
  canonical?: string
  locale?: LocaleCode
  alternateLocales?: AlternateLocale[]
}

const {
  title,
  cv,
  description,
  image,
  canonical,
  locale,
  alternateLocales,
} = Astro.props

const { basics, education } = cv
const { name, label, email, phone, summary, url, profiles } = basics
const site = Astro.site ?? new URL(Astro.url.origin)
const defaultOgImage = "/og-home.png"
const pageDescription = description ?? summary
const canonicalUrl = new URL(canonical ?? Astro.url.pathname, site)
const ogImageUrl = new URL(image || defaultOgImage, site)
const profileImageUrl = new URL(basics.image, site)
const currentOgLocale = locale ?? (Astro.currentLocale === "en" ? "en_US" : "es_AR")
const defaultAlternateLocales: AlternateLocale[] = [
  { locale: "es_AR", href: "/", hreflang: "es-AR" },
  { locale: "en_US", href: "/en/", hreflang: "en-US" },
]
const localeAlternates = alternateLocales ?? defaultAlternateLocales
const toHreflang = (value: string) => value.replace("_", "-")
const alternateLinks = localeAlternates.map((alternate) => ({
  ...alternate,
  href: new URL(alternate.href, site).href,
  hreflang: alternate.hreflang ?? toHreflang(alternate.locale),
}))
const xDefaultAlternate = alternateLinks.find(({ locale }) => locale === "es_AR") ?? alternateLinks[0]
const ogLocaleAlternates = [...new Set(
  localeAlternates
    .map(({ locale }) => locale)
    .filter((alternateLocale) => alternateLocale !== currentOgLocale)
)]
const sameAs = profiles?.map(({ url }: { url: string }) => url).filter(Boolean) ?? []
const currentWork = cv.work?.find(({ endDate }: { endDate: string | null }) => endDate === null) ?? cv.work?.[0]
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name,
  jobTitle: label,
  url: new URL(url, site).href,
  image: profileImageUrl.href,
  email: `mailto:${email}`,
  telephone: phone,
  sameAs,
  worksFor: currentWork?.name ? {
    "@type": "Organization",
    name: currentWork.name,
    ...(currentWork.url ? { url: currentWork.url } : {}),
  } : undefined,
  alumniOf: education?.[0]?.institution ? {
    "@type": "CollegeOrUniversity",
    name: education[0].institution,
    ...(education[0].url ? { url: education[0].url } : {}),
  } : undefined,
  knowsAbout: [
    "Kubernetes",
    "AWS",
    "CI/CD",
    "DevOps",
    "Cloud Infrastructure",
  ],
}
const safeJsonLd = JSON.stringify(jsonLd).replace(/</g, "\\u003c")
---

<!doctype html>
<html lang={Astro.currentLocale || "es"}>
  <head>
    <meta charset="UTF-8" />
    <title>{title}</title>
    <meta name="description" content={pageDescription} />
    <meta name="viewport" content="width=device-width" />
    <link rel="canonical" href={canonicalUrl.href} />
    {alternateLinks.map(({ href, hreflang }) => (
      <link rel="alternate" hreflang={hreflang} href={href} />
    ))}
    {xDefaultAlternate && (
      <link rel="alternate" hreflang="x-default" href={xDefaultAlternate.href} />
    )}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preload" as="image" href={basics.image} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:image" content={ogImageUrl.href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={currentOgLocale} />
    {ogLocaleAlternates.map((alternateLocale) => (
      <meta property="og:locale:alternate" content={alternateLocale} />
    ))}
    <meta property="og:site_name" content="Santiago Ariel Mansfeld" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImageUrl.href} />
    <script type="application/ld+json" set:html={safeJsonLd}></script>
    <script src="https://code.iconify.design/iconify-icon/2.1.0/iconify-icon.min.js"></script>
    <script is:inline>
      document.documentElement.classList.add('js');

      window.getThemePreference = () => {
        const override = new URLSearchParams(window.location.search).get('theme');
        if (override === 'light' || override === 'dark') return override;
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      };

      window.applyTheme = (theme) => {
        if (theme === 'dark') {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
      };

      const initTheme = () => {
        const theme = window.getThemePreference();
        window.applyTheme(theme);
      };

      initTheme();

      const initLang = () => {
        const storedLang = localStorage.getItem('lang');
        const currentIsEn = window.location.pathname.startsWith('/en');

        if (storedLang === 'en' && !currentIsEn) {
          window.location.replace('/en/');
        } else if (storedLang === 'es' && currentIsEn) {
          window.location.replace('/');
        } else if (!storedLang) {
          const browserIsEn = navigator.language.startsWith('en');
          if (browserIsEn && !currentIsEn) {
            window.location.replace('/en/');
          } else if (!browserIsEn && currentIsEn) {
            window.location.replace('/');
          }
        }
      };

      initLang();
    </script>
    <Clarity id="x9rpajde8s" />
    <script>
      import "@/analytics/tracking";
    </script>
    <script>
      // Reveal-on-scroll: elements marked [data-reveal] fade in as they enter
      // the viewport. Gated on html.js so content is never hidden without JS,
      // and on prefers-reduced-motion via CSS.
      const reveal = () => {
        const targets = document.querySelectorAll("[data-reveal]");
        if (!targets.length) return;

        if (!("IntersectionObserver" in window)) {
          targets.forEach((el) => el.classList.add("revealed"));
          return;
        }

        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("revealed");
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.12, rootMargin: "0px 0px -8% 0px" });

        targets.forEach((el) => observer.observe(el));
      };

      reveal();
    </script>
  </head>
  <body>
    <AIContext />
    <div class="bg-effects" aria-hidden="true">
      <div class="bg-grid"></div>
      <div class="bg-aurora"></div>
      <div class="bg-radial-light"></div>
      <div class="bg-scanlines"></div>
      <div class="bg-noise"></div>
      <div class="bg-vignette"></div>
    </div>

    <div class="app-layout">
      <slot />
    </div>
  </body>
</html>

<style is:global>
  :root {
    /* ── Surfaces ── */
    --bg-primary: #050508;
    --bg-secondary: #0A0A12;
    --bg-panel: #0C0C15;
    --bg-panel-hover: #10101B;

    /* ── Text ── */
    --text-primary: #EDEBF6;
    --text-secondary: #A29AB8;
    --text-muted: #625A7C;

    /* ── Lines ── */
    --border-color: rgba(139, 92, 246, 0.14);
    --border-hover: rgba(160, 120, 255, 0.32);
    --border-strong: rgba(139, 92, 246, 0.45);

    /* ── Accents ── */
    --accent-purple: #8B5CF6;
    --accent-purple-bright: #A78BFA;
    --accent-purple-dim: rgba(139, 92, 246, 0.12);
    --accent-cyan: #22D3EE;
    --accent-cyan-dim: rgba(34, 211, 238, 0.1);
    --accent-green: #4ADE80;
    --accent-green-dim: rgba(74, 222, 128, 0.12);
    --accent-amber: #FBBF24;

    /* ── Effects ── */
    --glow-purple: 0 0 24px rgba(139, 92, 246, 0.16);
    --glow-border: 0 0 12px rgba(139, 92, 246, 0.1);
    --glow-green: 0 0 8px rgba(74, 222, 128, 0.5);
    --scanline-color: rgba(0, 0, 0, 0.22);

    /* ── Type ── */
    --font-heading: 'Space Grotesk', system-ui, sans-serif;
    --font-body: 'Inter', system-ui, sans-serif;
    --font-mono: 'JetBrains Mono', 'Fira Code', monospace;

    /* ── Geometry ── */
    --radius-sm: 2px;
    --radius-md: 4px;
    --container-max: 1060px;
    --container-pad: 32px;
    --topbar-h: 48px;

    /* ── Motion ── */
    --transition-fast: 150ms ease;
    --transition-normal: 250ms ease;
    --ease-out-soft: cubic-bezier(0.22, 1, 0.36, 1);
  }

  :root:not(.dark) {
    --bg-primary: #F7F5FB;
    --bg-secondary: #EFEBF7;
    --bg-panel: #FFFFFF;
    --bg-panel-hover: #F7F4FC;

    --text-primary: #17121F;
    --text-secondary: #4E4763;
    --text-muted: #837BA0;

    --border-color: rgba(109, 66, 199, 0.16);
    --border-hover: rgba(109, 66, 199, 0.38);
    --border-strong: rgba(109, 66, 199, 0.5);

    --accent-purple: #6D28D9;
    --accent-purple-bright: #7C3AED;
    --accent-purple-dim: rgba(109, 40, 217, 0.08);
    --accent-cyan: #0E7490;
    --accent-cyan-dim: rgba(14, 116, 144, 0.08);
    --accent-green: #15803D;
    --accent-green-dim: rgba(21, 128, 61, 0.1);
    --accent-amber: #B45309;

    --glow-purple: 0 0 24px rgba(109, 40, 217, 0.07);
    --glow-border: 0 0 12px rgba(109, 40, 217, 0.05);
    --glow-green: 0 0 6px rgba(21, 128, 61, 0.35);
    --scanline-color: rgba(60, 40, 110, 0.04);
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
    scroll-padding-top: calc(var(--topbar-h) + 24px);
    background: var(--bg-primary);
    color: var(--text-primary);
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    min-height: 100vh;
    overflow-x: hidden;
    font-size: 0.95rem;
  }

  a {
    text-decoration: none;
    color: inherit;
  }

  ul {
    list-style: none;
  }

  h1, h2, h3, h4, h5, h6 {
    font-family: var(--font-heading);
    font-weight: 500;
    line-height: 1.25;
    color: var(--text-primary);
  }

  p {
    color: var(--text-secondary);
    line-height: 1.7;
  }

  ::selection {
    background: rgba(139, 92, 246, 0.35);
    color: var(--text-primary);
  }

  :focus-visible {
    outline: 1px solid var(--accent-purple);
    outline-offset: 3px;
  }

  ::-webkit-scrollbar {
    width: 10px;
  }

  ::-webkit-scrollbar-track {
    background: var(--bg-primary);
  }

  ::-webkit-scrollbar-thumb {
    background: var(--border-color);
    border: 2px solid var(--bg-primary);
  }

  ::-webkit-scrollbar-thumb:hover {
    background: var(--border-hover);
  }

  @supports (scrollbar-width: thin) {
    html {
      scrollbar-width: thin;
      scrollbar-color: var(--border-color) var(--bg-primary);
    }
  }

  /* ── Reveal-on-scroll ─────────────────────────────────────────────
     Hidden state only applies when JS is running (html.js) and the
     user has not requested reduced motion. */
  @media (prefers-reduced-motion: no-preference) {
    html.js [data-reveal] {
      opacity: 0;
      transform: translateY(16px);
      transition:
        opacity 600ms var(--ease-out-soft),
        transform 600ms var(--ease-out-soft);
      transition-delay: var(--reveal-delay, 0ms);
    }

    html.js [data-reveal].revealed {
      opacity: 1;
      transform: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }

    html {
      scroll-behavior: auto;
    }
  }

  /* ── Background stack ── */
  .bg-effects {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .bg-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--border-color) 1px, transparent 1px),
      linear-gradient(90deg, var(--border-color) 1px, transparent 1px);
    background-size: 56px 56px;
    opacity: 0.35;
    mask-image: radial-gradient(ellipse 90% 80% at 50% 0%, black 30%, transparent 90%);
    -webkit-mask-image: radial-gradient(ellipse 90% 80% at 50% 0%, black 30%, transparent 90%);
  }

  .bg-aurora {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 50% at 18% 35%, rgba(139, 92, 246, 0.05), transparent),
      radial-gradient(ellipse 55% 40% at 82% 65%, rgba(34, 211, 238, 0.035), transparent);
    animation: fogDrift 24s ease-in-out infinite alternate;
  }

  @keyframes fogDrift {
    0% { transform: translate(0, 0); }
    100% { transform: translate(-2%, 1.5%); }
  }

  .bg-radial-light {
    position: absolute;
    top: -22%;
    right: -12%;
    width: 62%;
    height: 62%;
    background: radial-gradient(circle, rgba(139, 92, 246, 0.07), transparent 70%);
    filter: blur(48px);
  }

  .bg-scanlines {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      to bottom,
      transparent 0,
      transparent 3px,
      var(--scanline-color) 3px,
      var(--scanline-color) 4px
    );
    opacity: 0.14;
  }

  .bg-noise {
    position: absolute;
    inset: 0;
    opacity: 0.015;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 256px 256px;
  }

  .bg-vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 120% 100% at 50% 40%, transparent 60%, rgba(0, 0, 0, 0.28) 100%);
  }

  :root:not(.dark) .bg-vignette {
    background: none;
  }

  .app-layout {
    position: relative;
    z-index: 1;
    min-height: 100vh;
  }

  /* ── Print ── */
  .print {
    display: none !important;
  }

  @media print {
    /* Force light tokens on paper regardless of the active theme */
    :root,
    :root.dark {
      --bg-primary: #FFFFFF;
      --bg-secondary: #F4F2F8;
      --bg-panel: #FFFFFF;
      --bg-panel-hover: #FFFFFF;
      --text-primary: #111111;
      --text-secondary: #333333;
      --text-muted: #666666;
      --border-color: rgba(0, 0, 0, 0.2);
      --border-hover: rgba(0, 0, 0, 0.3);
      --border-strong: rgba(0, 0, 0, 0.4);
      --accent-purple: #5B21B6;
      --accent-purple-bright: #5B21B6;
      --accent-purple-dim: transparent;
      --accent-cyan: #0E7490;
      --accent-cyan-dim: transparent;
      --accent-green: #166534;
      --accent-green-dim: transparent;
      --accent-amber: #92400E;
      --glow-purple: none;
      --glow-border: none;
      --glow-green: none;
    }

    .no-print {
      display: none !important;
    }

    .print {
      display: block !important;
    }

    .bg-effects {
      display: none;
    }

    html.js [data-reveal] {
      opacity: 1 !important;
      transform: none !important;
    }

    article {
      break-inside: avoid;
    }

    html {
      background: #fff;
      color: #000;
    }
  }
</style>
